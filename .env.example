# ─── MiniMax T2A v2 (backend TTS) ────────────────────────────────────────────
# Get both values from https://platform.minimaxi.com/user-center/basic-information
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Optional overrides
MINIMAX_API_BASE=https://api.minimax.chat
MINIMAX_MODEL=speech-02-hd

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8787
HOST=127.0.0.1

# Filesystem cache for synthesized mp3 (sha256-keyed)
CACHE_DIR=.cache

# Optional: serve dist/ from the same Fastify process (set to ../dist for combined dev).
STATIC_DIR=

# CORS — use * for local dev; tighten in production
CORS_ORIGIN=*
