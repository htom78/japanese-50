    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.0",
    "zod": "^3.23.0",
    "undici": "^6.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
